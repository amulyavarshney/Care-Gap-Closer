# ── Required ──────────────────────────────────────────────────────────────────
# Gemini via Google AI Studio. Free tier: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# API key clients (and PO portal) must send as X-API-Key.
API_KEY_PRIMARY=demo-key

# If this agent is registered on a marketplace and used by more than one PO
# workspace, issue each workspace its own key instead of sharing API_KEY_PRIMARY
# — that way a single leaked/rotated key doesn't affect every integration.
# API_KEY_PRIMARY still works as a single fallback key; API_KEYS is additive
# (both are accepted at once). See shared/middleware.py:_load_valid_api_keys.
# API_KEYS=workspace-a-key,workspace-b-key,workspace-c-key

# Where the care_gap_mcp server is reachable from this agent.
# Local dev: leave as-is.  Through ngrok: https://<your-mcp-tunnel>/mcp
MCP_SERVER_URL=http://127.0.0.1:9000/mcp

# ── Optional ──────────────────────────────────────────────────────────────────
# Public URL the agent card should advertise. Set to your ngrok URL when
# registering with Prompt Opinion. Leave unset for local-only testing.
# BASE_URL=https://my-tunnel.ngrok-free.app
# CARE_GAP_AGENT_URL=https://my-tunnel.ngrok-free.app

# Prompt Opinion workspace base — used as the FHIR extension URI prefix.
# Default: https://app.promptopinion.ai
# PO_PLATFORM_BASE_URL=https://app.promptopinion.ai

# Browser playground (GitHub Pages) CORS — comma-separated origins, or *
# Defaults already include https://amulyavarshney.github.io when unset.
# CORS_ORIGINS=https://amulyavarshney.github.io,http://localhost:5500

# Override Gemini model used by the agent / MCP rationale tools.
# CARE_GAP_AGENT_MODEL=gemini/gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_FULL_PAYLOAD=true
# LOG_HOOK_RAW_OBJECTS=false
